<h1>Edit Movie</h1>

<% if @movie.errors.any? %>
  <div style="background-color: #fee; border: 1px solid #fcc; border-radius: 4px; padding: 15px; margin-bottom: 20px; color: #c33;">
    <h3 style="margin-top: 0; color: #c33;">❌ Cannot update the movie:</h3>
    <ul style="margin: 10px 0;">
      <% @movie.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @movie do |f| %>

  <p>
    <label>Title:</label> <%= f.text_field :title %>
  </p>

  <p>
    <label>Rating:</label> <%= f.text_field :rating %>
  </p>

  <p>
    <label>Description:</label> <%= f.text_area :description %>
  </p>

  <p>
    <label>Release Date:</label> <%= f.date_select :release_date %>
  </p>

  <p>
    <%= f.submit "Update Movie", style: "padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer;" %>
  </p>

<% end %>

<%= link_to "Back to Movie", movie_path(@movie), style: "text-decoration: none; color: #007bff;" %>