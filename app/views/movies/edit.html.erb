<h2>✏️ Edit Movie</h2>

<div style="background: white; border-radius: 8px; padding: 30px; max-width: 600px; margin: 0 auto; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
  <% if @movie.errors.any? %>
    <div style="background-color: #fee; border: 1px solid #fcc; border-radius: 6px; padding: 15px; margin-bottom: 20px; color: #c33;">
      <h3 style="margin-top: 0; color: #c33;">❌ Cannot update the movie:</h3>
      <ul style="margin: 10px 0; padding-left: 20px;">
        <% @movie.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @movie do |f| %>
    <div style="margin-bottom: 18px;">
      <label><strong>🎬 Movie Title</strong> (2-200 characters)</label>
      <%= f.text_field :title, placeholder: "Enter movie title", required: true, minlength: 2, maxlength: 200 %>
    </div>

    <div style="margin-bottom: 18px;">
      <label><strong>⭐ Rating</strong> (required)</label>
      <%= f.select :rating, (0..5).to_a, {}, required: true %>
    </div>

    <div style="margin-bottom: 18px;">
      <label><strong>📝 Description</strong> (10-1000 characters)</label>
      <%= f.text_area :description, placeholder: "Describe the movie (minimum 10 characters)...", style: "min-height: 130px;", required: true, minlength: 10, maxlength: 1000 %>
      <small style="color: #666; display: block; margin-top: 5px;">
        <span id="char-count"><%= @movie.description.length %></span>/1000 characters
      </small>
    </div>

    <div style="margin-bottom: 18px;">
      <label><strong>📅 Release Date</strong> (required, cannot be in the future)</label>
      <%= f.date_field :release_date, required: true, max: Date.today.to_s %>
    </div>

    <div style="margin-top: 25px; display: flex; gap: 10px;">
      <input type="submit" value="💾 Update Movie" class="btn btn-success" style="flex: 1;" />
      <%= link_to "↩️ Back to Movie", movie_path(@movie), class: "btn btn-primary", style: "flex: 1; text-align: center;" %>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const descriptionField = document.querySelector('textarea[name="movie[description]"]');
    const charCount = document.getElementById('char-count');
    
    if (descriptionField && charCount) {
      descriptionField.addEventListener('input', function() {
        charCount.textContent = this.value.length;
        
        // Visual feedback
        if (this.value.length < 10) {
          charCount.style.color = '#dc3545';
        } else if (this.value.length > 900) {
          charCount.style.color = '#ffc107';
        } else {
          charCount.style.color = '#28a745';
        }
      });
    }
  });
</script>