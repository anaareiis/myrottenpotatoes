<h1>All Movies</h1>

<p>
  <%= link_to "Add New Movie", new_movie_path, style: "padding: 8px 16px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px; display: inline-block;" %>
</p>

<% if @movies.any? %>
  <ul style="list-style: none; padding: 0;">
    <% @movies.each do |movie| %>
      <li style="padding: 10px; border-bottom: 1px solid #ddd;">
        <strong><%= movie.title %></strong> - Rating: <%= movie.rating %>
        <% if movie.description.present? %>
          <br/>
          <small style="color: #666;"><%= truncate(movie.description, length: 100) %></small>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No movies available. <%= link_to "Create one now!", new_movie_path %></p>
<% end %>