<h1>🍿 All Movies</h1>

<div style="margin-bottom: 20px; text-align: right;">
  <%= link_to "➕ Add New Movie", new_movie_path, class: "btn btn-primary" %>
</div>

<!-- Filter by Rating -->
<form method="get" action="<%= movies_path %>" style="margin-bottom: 30px;">
  <div style="display: flex; gap: 15px; align-items: flex-end;">
    <div>
      <label>Filter by Rating:</label>
      <select name="rating" style="padding: 10px; border-radius: 6px; border: 1px solid #ddd;">
        <option value="" <%= 'selected' if params[:rating].blank? %>>All Ratings</option>
        <option value="0" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 0 %>>⭐ 0 stars</option>
        <option value="1" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 1 %>>⭐ 1 star</option>
        <option value="2" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 2 %>>⭐ 2 stars</option>
        <option value="3" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 3 %>>⭐ 3 stars</option>
        <option value="4" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 4 %>>⭐ 4 stars</option>
        <option value="5" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 5 %>>⭐ 5 stars</option>
      </select>
    </div>
    <div>
      <input type="submit" value="Apply Filter" class="btn btn-success" style="padding: 10px 20px; margin-bottom: 17px;" />
    </div>
  </div>
</form>

<% if @movies.any? %>
  <table style="width: 100%; border-collapse: collapse; background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-radius: 8px; overflow: hidden;">
    <thead>
      <tr style="background: #667eea; color: white;">
        <th style="padding: 15px; text-align: left; cursor: pointer; user-select: none; <%= 'background: #5568d3;' if @title_header %>">
          <% title_sort_order = params[:sort_by] == 'title' && params[:sort_order] != 'desc' ? 'desc' : 'asc' %>
          <%= link_to "Title #{@title_header}", movies_path(sort_by: 'title', sort_order: title_sort_order, rating: params[:rating]), style: "color: white; text-decoration: none; font-weight: bold;" %>
        </th>
        <th style="padding: 15px; text-align: left;">Rating</th>
        <th style="padding: 15px; text-align: left; cursor: pointer; user-select: none; <%= 'background: #5568d3;' if @release_date_header %>">
          <% date_sort_order = params[:sort_by] == 'release_date' && params[:sort_order] != 'desc' ? 'desc' : 'asc' %>
          <%= link_to "Release Date #{@release_date_header}", movies_path(sort_by: 'release_date', sort_order: date_sort_order, rating: params[:rating]), style: "color: white; text-decoration: none; font-weight: bold;" %>
        </th>
        <th style="padding: 15px; text-align: center;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @movies.each do |movie| %>
        <tr style="border-bottom: 1px solid #eee; transition: background 0.2s;">
          <td style="padding: 15px;">
            <%= link_to movie.title, movie_path(movie), style: "color: #667eea; text-decoration: none; font-weight: 600;" %>
          </td>
          <td style="padding: 15px;">
            <span style="background: #667eea; color: white; padding: 6px 10px; border-radius: 4px; font-weight: bold;">
              ⭐ <%= movie.rating %>/5
            </span>
          </td>
          <td style="padding: 15px;">
            <%= movie.release_date.strftime("%b %d, %Y") if movie.release_date %>
          </td>
          <td style="padding: 15px; text-align: center;">
            <div style="display: flex; gap: 8px; justify-content: center;">
              <%= link_to "View", movie_path(movie), class: "btn btn-primary", style: "padding: 6px 12px; font-size: 12px;" %>
              <%= link_to "Edit", edit_movie_path(movie), class: "btn btn-warning", style: "padding: 6px 12px; font-size: 12px;" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div style="background: white; border-radius: 8px; padding: 40px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
    <p style="font-size: 18px; color: #666; margin-bottom: 20px;">
      😢 No movies found. Start adding some!
    </p>
    <%= link_to "➕ Create the first movie!", new_movie_path, class: "btn btn-primary" %>
  </div>
<% end %>