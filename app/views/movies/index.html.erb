<h1>All Movies</h1>

<p>
  <%= link_to "Add New Movie", new_movie_path, 
      style: "padding: 8px 16px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px; display: inline-block;" %>
</p>

<div style="margin-bottom: 20px;">
  <form method="get" action="<%= movies_path %>" style="display: inline;">
    <label style="margin-right: 10px;">Filter by Rating:</label>
    <select name="rating" style="padding: 6px; border-radius: 4px; border: 1px solid #ddd;">
      <option value="" <%= 'selected' if params[:rating].blank? %>>All Ratings</option>
      <option value="0" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 0 %>>0</option>
      <option value="1" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 1 %>>1</option>
      <option value="2" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 2 %>>2</option>
      <option value="3" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 3 %>>3</option>
      <option value="4" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 4 %>>4</option>
      <option value="5" <%= 'selected' if params[:rating].present? && params[:rating].to_i == 5 %>>5</option>
    </select>
    
    <label style="margin-left: 20px; margin-right: 10px;">Sort by:</label>
    <select name="sort" style="padding: 6px; border-radius: 4px; border: 1px solid #ddd;">
      <option value="">Newest First</option>
      <option value="title_asc" <%= 'selected' if params[:sort] == 'title_asc' %>>Title (A-Z)</option>
      <option value="title_desc" <%= 'selected' if params[:sort] == 'title_desc' %>>Title (Z-A)</option>
      <option value="rating_desc" <%= 'selected' if params[:sort] == 'rating_desc' %>>Rating (High to Low)</option>
      <option value="rating_asc" <%= 'selected' if params[:sort] == 'rating_asc' %>>Rating (Low to High)</option>
      <option value="date_desc" <%= 'selected' if params[:sort] == 'date_desc' %>>Release Date (Newest)</option>
      <option value="date_asc" <%= 'selected' if params[:sort] == 'date_asc' %>>Release Date (Oldest)</option>
    </select>
    
    <input type="submit" value="Apply" style="padding: 6px 12px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; margin-left: 10px;" />
  </form>
</div>

<% if @movies.any? %>
  <ul style="list-style: none; padding: 0;">
    <% @movies.each do |movie| %>
      <li style="padding: 12px; border-bottom: 1px solid #ddd;">

        <strong style="font-size: 18px;">
          <%= link_to movie.title, movie_path(movie), style: "text-decoration: none; color: #333;" %>
        </strong>

        <p style="margin: 5px 0;">
          <strong>Rating:</strong> <%= movie.rating %>
        </p>

        <% if movie.description.present? %>
          <p style="margin: 5px 0; color: #666;">
            <%= truncate(movie.description, length: 100) %>
          </p>
        <% end %>

      </li>
    <% end %>
  </ul>
<% else %>
  <p>
    No movies available. 
    <%= link_to "Create one now!", new_movie_path %>
  </p>
<% end %>