<div style="background: white; border-radius: 8px; padding: 30px; max-width: 700px; margin: 0 auto; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-top: 30px;">
  <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 25px; border-bottom: 2px solid #f0f0f0; padding-bottom: 20px;">
    <div>
      <h3 style="margin: 0 0 10px 0; color: #333;"><%= @movie.title %></h3>
      <p style="margin: 0; color: #666; font-size: 14px;">
        📅 Released: <%= @movie.release_date.strftime("%B %d, %Y") if @movie.release_date %>
      </p>
    </div>
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 15px 20px; border-radius: 8px; text-align: center; min-width: 100px;">
      <div style="font-size: 28px; font-weight: bold;">⭐ <%= @movie.rating %></div>
      <div style="font-size: 12px; margin-top: 5px;">out of 5</div>
    </div>
  </div>

  <div style="margin-bottom: 25px;">
    <h4 style="color: #333; margin-bottom: 10px;">📝 Description</h4>
    <p style="color: #666; line-height: 1.7; font-size: 15px;">
      <%= @movie.description %>
    </p>
  </div>

  <div style="margin-top: 30px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
    <%= link_to "✏️ Edit", edit_movie_path(@movie), style: "padding: 10px 18px; height: 44px; display: flex; align-items: center; background-color: #ffc107; color: #333; border: none; border-radius: 6px; text-decoration: none; cursor: pointer; font-weight: 500; transition: all 0.3s;" %>
    <%= button_to "🗑️ Delete", movie_path(@movie), 
        method: :delete,
        form: { style: "display: inline; margin: 0;" },
        data: { confirm: "Are you sure?" },
        style: "padding: 10px 18px; height: 44px; background-color: #dc3545; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 500; transition: all 0.3s; margin: 0; display: flex; align-items: center;" %>
    <%= link_to "↩️ Back to Movies", movies_path, style: "padding: 10px 18px; height: 44px; display: flex; align-items: center; background-color: #007bff; color: white; border: none; border-radius: 6px; text-decoration: none; cursor: pointer; font-weight: 500; transition: all 0.3s;" %>
  </div>
</div>