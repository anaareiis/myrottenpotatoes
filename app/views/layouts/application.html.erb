<!DOCTYPE html>
<html>
  <head>
    <title>Myrottenpotatoes</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <style>
      body { font-family: Arial, sans-serif; margin: 20px; }
      .alert { padding: 15px; margin-bottom: 20px; border-radius: 4px; }
      .alert-notice { background-color: #d4edda; border: 1px solid #c3e6cb; color: #155724; }
      .alert-alert { background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; }
    </style>
  </head>

  <body>
    <% if notice %>
      <div class="alert alert-notice">✅ <%= notice %></div>
    <% end %>

    <% if alert %>
      <div class="alert alert-alert">⚠️ <%= alert %></div>
    <% end %>

    <%= yield %>
  </body>
</html>
